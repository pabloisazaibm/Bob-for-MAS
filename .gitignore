# .gitignore — MAS Demo Framework

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env

# ── Generated output — regenerate with build_docs.py ─────────────────────────
output/*.docx
output/*.pdf

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
env/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Word temp files ───────────────────────────────────────────────────────────
~$*.docx
~$*.doc

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
