# Maximo Connection — Environment Variables
# -----------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your API key.
#
# Usage: the demo_loader.py script reads these automatically.
# You can also export them manually:
#   export $(cat .env | xargs)

# ── Maximo URLs ───────────────────────────────────────────────────────────────
# LOGIN_BASE: the frontend Manage host used to establish the session cookie
# Pattern:    https://<appid>.manage.<cluster>/maximo
#
# API_BASE:   where all data API calls are sent
#             On TechZone/MAS SaaS this is often the *-all.manage.* variant
#             If unsure, set to the same as LOGIN_BASE — the error message will
#             reveal the correct hostname.
# Pattern:    https://<appid>-all.manage.<cluster>/maximo
#
LOGIN_BASE=https://<your-manage-host>/maximo
API_BASE=https://<your-api-host>/maximo

# ── Authentication ────────────────────────────────────────────────────────────
# Generate in Maximo: top-right avatar → API Keys → Generate new key
MAXIMO_API_KEY=<your-api-key>

# ── Site / Org / Location ─────────────────────────────────────────────────────
# These must already exist in your Maximo instance.
# Ask Bob: "Query mxapilocation for location and description at site <SITE>"
MAXIMO_SITE=<SITE>          # e.g. BEDFORD
MAXIMO_ORG=<ORG>            # e.g. EAGLENA
MAXIMO_LOCATION=<LOCATION>  # e.g. CENTRAL  (valid operating location / storeroom)

# ── Owner (Person ID) ─────────────────────────────────────────────────────────
# IMPORTANT: this is PERSON.PERSONID — NOT the login/username.
# They often differ (login: jsmith, personid: JOHN SMITH — including spaces).
# Ask Bob: "Query mxapiperson for personid and displayname, 10 records"
MAXIMO_OWNER=<PERSON ID>    # e.g. PABLO ISAZA
